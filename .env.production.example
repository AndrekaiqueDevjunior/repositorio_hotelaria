# ============================================================
# AMBIENTE DE PRODUÇÃO - HOTEL CABO FRIO
# ============================================================
# INSTRUÇÕES:
# 1. Copie este arquivo para .env.production
# 2. Substitua TODOS os valores de exemplo por valores reais
# 3. NUNCA commite .env.production no Git!
# ============================================================

# ============================================================
# DOCKER COMPOSE
# ============================================================
COMPOSE_PROJECT_NAME=hotel_prod
FRONTEND_PORT=3000
BACKEND_PORT=8000

# ============================================================
# SSL - CERTIFICADOS NGINX
# ============================================================
# Em produção (VPS): aponte para os certs do Let's Encrypt
# SSL_CERT_PATH=/etc/letsencrypt/archive/hotelrealcabofrio.com/fullchain1.pem
# SSL_KEY_PATH=/etc/letsencrypt/archive/hotelrealcabofrio.com/privkey1.pem
# Em localhost: deixe em branco (usa ./ssl/ autoassinado gerado automaticamente)
# SSL_CERT_PATH=./ssl/fullchain.pem
# SSL_KEY_PATH=./ssl/privkey.pem

# ============================================================
# SEGURANÇA - GERAR CHAVES FORTES
# ============================================================
# Gerar com: openssl rand -hex 32
SECRET_KEY=GERAR_COM_OPENSSL_RAND_HEX_32
JWT_SECRET_KEY=GERAR_COM_OPENSSL_RAND_HEX_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============================================================
# ADMIN - SENHA SEGURA
# ============================================================
ADMIN_EMAIL=admin@hotelreal.com.br
ADMIN_PASSWORD=SENHA_SUPER_FORTE_AQUI
AUTH_PASSWORD=SENHA_SUPER_FORTE_AQUI

# ============================================================
# DATABASE - PRODUÇÃO
# ============================================================
# Formato: postgresql://usuario:senha@host:porta/database
DATABASE_URL=postgresql://hotel_user:SENHA_DB_FORTE@postgres:5432/hotel_cabo_frio_prod
PRISMA_CONNECTION_LIMIT=5
CELERY_PRISMA_CONNECTION_LIMIT=1
PRISMA_POOL_TIMEOUT_SECONDS=10
PRISMA_CONNECT_TIMEOUT_SECONDS=5
PRISMA_DISCONNECT_TIMEOUT_SECONDS=5
DB_USER=hotel_user
DB_PASSWORD=SENHA_DB_FORTE

# ============================================================
# REDIS - PRODUÇÃO
# ============================================================
REDIS_PASSWORD=SENHA_REDIS_FORTE
REDIS_URL=redis://:SENHA_REDIS_FORTE@redis:6379/0
CELERY_BROKER_URL=redis://:SENHA_REDIS_FORTE@redis:6379/1
CELERY_RESULT_BACKEND=redis://:SENHA_REDIS_FORTE@redis:6379/2
REDIS_HOST=redis
REDIS_PORT=6379

# ============================================================
# CORS - RESTRINGIR PARA DOMÍNIO REAL
# ============================================================
CORS_ORIGINS=https://hotelreal.com.br,https://www.hotelreal.com.br,http://localhost:3000,http://localhost:8000,http://127.0.0.1:3000,http://127.0.0.1:8000
FRONTEND_URL=https://hotelreal.com.br
FRONTEND_BASE_URL=https://hotelreal.com.br
NEXT_PUBLIC_API_URL=https://hotelreal.com.br/api/v1
NEXT_PUBLIC_SITE_URL=https://hotelreal.com.br
NEXT_PUBLIC_TEF_TLS_TOKEN=
NEXT_PUBLIC_TEF_IDLE_TIMEOUT_MS=300000
NEXT_PUBLIC_TEF_REQUEST_TIMEOUT_MS=180000

# ============================================================
# TWILIO WHATSAPP - JORNADA REAL
# ============================================================
TWILIO_WHATSAPP_ENABLED=true
TWILIO_ACCOUNT_SID=ACXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TWILIO_AUTH_TOKEN=SEU_AUTH_TOKEN_TWILIO
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
WHATSAPP_NOTIFICACAO_NUMERO=+5522999999999
TWILIO_WHATSAPP_SANDBOX_JOIN_CODE=

# ============================================================
# TWILIO SMS - COMPROVANTE TEF
# ============================================================
SMS_TWILIO_ACCOUNT_SID=ACXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
SMS_TWILIO_AUTH_TOKEN=SEU_AUTH_TOKEN_TWILIO
SMS_TWILIO_FROM_NUMBER=+5522999999999

# ============================================================
# SENDGRID - EMAILS E COMPROVANTE TEF
# ============================================================
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=noreply@hotelreal.com.br
SENDGRID_FROM_NAME=Hotel Real Cabo Frio
SENDGRID_RESERVAS_TO_EMAIL=reservas@hotelreal.com.br

# ============================================================
# OTP - JORNADA REAL
# ============================================================
OTP_HASH_SECRET=GERAR_COM_OPENSSL_RAND_HEX_32

# ============================================================
# COOKIES - PRODUÇÃO (HTTPS)
# ============================================================
COOKIE_NAME=hotel_auth_token
COOKIE_DOMAIN=.hotelreal.com.br
COOKIE_SECURE=True
COOKIE_SAMESITE=strict
COOKIE_HTTPONLY=True
COOKIE_MAX_AGE=604800

# ============================================================
# AMBIENTE
# ============================================================
APP_ENV=production
DEBUG=False
ENVIRONMENT=production
API_V1_PREFIX=/api/v1

# ============================================================
# CIELO - PRODUÇÃO (OBTER NO PORTAL CIELO)
# ============================================================
# https://www.cielo.com.br/
CIELO_MERCHANT_ID=SEU_MERCHANT_ID_PRODUCAO
CIELO_MERCHANT_KEY=SUA_MERCHANT_KEY_PRODUCAO
CIELO_MODE=production
CIELO_API_URL=https://api.cieloecommerce.cielo.com.br/
CIELO_SANDBOX_URL=https://apisandbox.cieloecommerce.cielo.com.br/
CIELO_TIMEOUT_MS=8000

# ============================================================
# TEF - PRODUÇÃO (CLISITEF)
# ============================================================
TEF_AGENTE_URL=https://host.docker.internal/agente/clisitef
TEF_AGENTE_MODE=real
TEF_AGENTE_VERIFY_SSL=false
TEF_TIMEOUT=60
TEF_SESSION_TIMEOUT=60
TEF_TIMEZONE=America/Sao_Paulo
TEF_SITEF_IP=
TEF_STORE_ID=
TEF_TERMINAL_ID=
TEF_CASHIER_OPERATOR=
TEF_SESSION_PARAMETERS=
TEF_TRN_INIT_PARAMETERS=
TEF_TRN_PARAMETERS=
TEF_PARMSCLIENT_PREFIX=ParmsClient=>
TEF_CNPJ_ESTAB=
TEF_CNPJ_AUTOMACAO=
TEF_PARAMETROS_ADICIONAIS=
TEF_SUPERVISOR_PASSWORD=
TEF_AUTO_RESOLVE_PENDING=false
TEF_AUTO_RESOLVE_PENDING_ACTION=confirm

# ============================================================
# ANTIFRAUDE - PRODUÇÃO
# ============================================================
ANTIFRAUDE_RISK_THRESHOLD_AUTO=30
ANTIFRAUDE_RISK_THRESHOLD_REJECT=70
RECAPTCHA_SECRET_KEY=CHAVE_SECRETA_RECAPTCHA_V3
RECAPTCHA_MIN_SCORE=0.5
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=CHAVE_PUBLICA_RECAPTCHA_V3
TURNSTILE_SECRET_KEY=CHAVE_SECRETA_TURNSTILE
NEXT_PUBLIC_TURNSTILE_SITE_KEY=CHAVE_PUBLICA_TURNSTILE

# ============================================================
# MONITORAMENTO (OPCIONAL)
# ============================================================
SENTRY_DSN=
LOG_LEVEL=INFO

# ============================================================
# BACKUP
# ============================================================
BACKUP_RETENTION_DAYS=30
