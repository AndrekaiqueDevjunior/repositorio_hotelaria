# ============================================================
# AMBIENTE DE PRODUÇÃO - HOTEL CABO FRIO
# ============================================================
# INSTRUÇÕES:
# 1. Copie este arquivo para .env.production
# 2. Substitua TODOS os valores de exemplo por valores reais
# 3. NUNCA commite .env.production no Git!
# ============================================================

# ============================================================
# DOCKER COMPOSE
# ============================================================
COMPOSE_PROJECT_NAME=hotel_prod

# ============================================================
# SEGURANÇA - GERAR CHAVES FORTES
# ============================================================
# Gerar com: openssl rand -hex 32
SECRET_KEY=GERAR_COM_OPENSSL_RAND_HEX_32
JWT_SECRET_KEY=GERAR_COM_OPENSSL_RAND_HEX_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============================================================
# ADMIN - SENHA SEGURA
# ============================================================
ADMIN_EMAIL=admin@hotelreal.com.br
ADMIN_PASSWORD=SENHA_SUPER_FORTE_AQUI

# ============================================================
# DATABASE - PRODUÇÃO
# ============================================================
# Formato: postgresql://usuario:senha@host:porta/database
DATABASE_URL=postgresql://hotel_user:SENHA_DB_FORTE@postgres:5432/hotel_cabo_frio_prod
DB_USER=hotel_user
DB_PASSWORD=SENHA_DB_FORTE

# ============================================================
# REDIS - PRODUÇÃO
# ============================================================
REDIS_PASSWORD=SENHA_REDIS_FORTE
REDIS_URL=redis://:SENHA_REDIS_FORTE@redis:6379/0
CELERY_BROKER_URL=redis://:SENHA_REDIS_FORTE@redis:6379/1
CELERY_RESULT_BACKEND=redis://:SENHA_REDIS_FORTE@redis:6379/2

# ============================================================
# CORS - RESTRINGIR PARA DOMÍNIO REAL
# ============================================================
CORS_ORIGINS=https://hotelreal.com.br,https://www.hotelreal.com.br
FRONTEND_URL=https://hotelreal.com.br
NEXT_PUBLIC_API_URL=https://hotelreal.com.br/api/v1
NEXT_PUBLIC_TEF_TLS_TOKEN=1111-2222-3333-4444

# ============================================================
# COOKIES - PRODUÇÃO (HTTPS)
# ============================================================
COOKIE_NAME=hotel_auth_token
COOKIE_DOMAIN=.hotelreal.com.br
COOKIE_SECURE=True
COOKIE_SAMESITE=strict
COOKIE_HTTPONLY=True
COOKIE_MAX_AGE=604800

# ============================================================
# AMBIENTE
# ============================================================
APP_ENV=production
DEBUG=False
ENVIRONMENT=production
API_V1_PREFIX=/api/v1

# ============================================================
# CIELO - PRODUÇÃO (OBTER NO PORTAL CIELO)
# ============================================================
# https://www.cielo.com.br/
CIELO_MERCHANT_ID=SEU_MERCHANT_ID_PRODUCAO
CIELO_MERCHANT_KEY=SUA_MERCHANT_KEY_PRODUCAO
CIELO_MODE=production
CIELO_API_URL=https://api.cieloecommerce.cielo.com.br/
CIELO_TIMEOUT_MS=8000

# ============================================================
# TEF - PRODUÇÃO (CLISITEF)
# ============================================================
TEF_AGENTE_URL=https://host.docker.internal/agente/clisitef
TEF_AGENTE_MODE=real
TEF_AGENTE_VERIFY_SSL=false
TEF_TIMEOUT=60
TEF_SESSION_TIMEOUT=60
TEF_SITEF_IP=
TEF_STORE_ID=
TEF_TERMINAL_ID=
TEF_CASHIER_OPERATOR=
TEF_SESSION_PARAMETERS=
TEF_TRN_INIT_PARAMETERS=[TipoComunicacaoExterna=TLSGWP;TokenRegistro=1111-2222-3333-4444]
TEF_TRN_PARAMETERS=
TEF_PARMSCLIENT_PREFIX=ParmsClient=>
TEF_CNPJ_ESTAB=
TEF_CNPJ_AUTOMACAO=
TEF_PARAMETROS_ADICIONAIS=
TEF_AUTO_RESOLVE_PENDING=false

# ============================================================
# ANTIFRAUDE - PRODUÇÃO
# ============================================================
ANTIFRAUDE_RISK_THRESHOLD_AUTO=30
ANTIFRAUDE_RISK_THRESHOLD_REJECT=70
RECAPTCHA_SECRET_KEY=CHAVE_SECRETA_RECAPTCHA_V3
RECAPTCHA_MIN_SCORE=0.5
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=CHAVE_PUBLICA_RECAPTCHA_V3
TURNSTILE_SECRET_KEY=CHAVE_SECRETA_TURNSTILE
NEXT_PUBLIC_TURNSTILE_SITE_KEY=CHAVE_PUBLICA_TURNSTILE

# ============================================================
# MONITORAMENTO (OPCIONAL)
# ============================================================
SENTRY_DSN=
LOG_LEVEL=INFO

# ============================================================
# BACKUP
# ============================================================
BACKUP_RETENTION_DAYS=30
