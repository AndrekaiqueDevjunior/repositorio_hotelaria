# Database Configuration
DATABASE_URL="postgresql://postgres:senha@localhost:5432/hotel_cabo_frio"

# Redis Configuration
REDIS_URL="redis://localhost:6379/0"

# JWT Configuration
JWT_SECRET_KEY="sua-chave-secreta-aqui"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# API Configuration
API_V1_STR="/api/v1"
PROJECT_NAME="Hotel Real Cabo Frio"
VERSION="1.0.0"

# CORS Configuration
BACKEND_CORS_ORIGINS=["http://localhost:3000", "https://hotelrealcabofrio.com"]

# External Services
CIELO_ENVIRONMENT="sandbox"
CIELO_MERCHANT_ID="seu-merchant-id"
CIELO_MERCHANT_KEY="sua-merchant-key"
RECAPTCHA_SECRET_KEY=""
RECAPTCHA_MIN_SCORE=0.5
TURNSTILE_SECRET_KEY=""

# TEF (CliSiTef)
TEF_AGENTE_URL="http://localhost:9999"
TEF_TIMEOUT=60
TEF_SESSION_TIMEOUT=60
TEF_SITEF_IP=""
TEF_STORE_ID=""
TEF_TERMINAL_ID=""
TEF_CASHIER_OPERATOR=""
TEF_SESSION_PARAMETERS=""
# TLS: manter vazio por padrao e enviar TokenRegistro apenas no startTransaction (funcao 699)
TEF_TRN_INIT_PARAMETERS=""
TEF_TRN_PARAMETERS=""
TEF_PARMSCLIENT_PREFIX="ParmsClient=>"
TEF_CNPJ_ESTAB=""
TEF_CNPJ_AUTOMACAO=""
TEF_PARAMETROS_ADICIONAIS=""
TEF_SUPERVISOR_PASSWORD=""
TEF_AUTO_RESOLVE_PENDING=false

# Email Configuration (opcional)
SMTP_TLS=true
SMTP_PORT=587
SMTP_HOST="smtp.gmail.com"
SMTP_USER="seu-email@gmail.com"
SMTP_PASSWORD="sua-senha"
EMAILS_FROM_EMAIL="noreply@hotelrealcabofrio.com"
EMAILS_FROM_NAME="Hotel Real Cabo Frio"

# SendGrid (notificacoes e comprovantes TEF)
SENDGRID_API_KEY=""
SENDGRID_FROM_EMAIL=""
SENDGRID_FROM_NAME="Hotel Real Cabo Frio"
SENDGRID_RESERVAS_TO_EMAIL=""

# SMS (Twilio)
SMS_TWILIO_ACCOUNT_SID=""
SMS_TWILIO_AUTH_TOKEN=""
SMS_TWILIO_FROM_NUMBER=""

# Twilio WhatsApp
TWILIO_WHATSAPP_ENABLED=true
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"
WHATSAPP_NOTIFICACAO_NUMERO="+5500000000000"
TWILIO_WHATSAPP_SANDBOX_JOIN_CODE="join seu-codigo"

# Upload Configuration
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE=10485760

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# Logging
LOG_LEVEL="INFO"

# Frontend Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=""
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
NEXT_PUBLIC_TEF_IDLE_TIMEOUT_MS=60000
NEXT_PUBLIC_TEF_REQUEST_TIMEOUT_MS=60000
